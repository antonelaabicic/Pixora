@inject AuthStateService AuthService
@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation
@implements IDisposable
@rendermode InteractiveServer
@inject JwtService JwtService
@inject AuthorizedHttpClient AuthorizedClient

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Pixora</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="flex-column">

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">Home</NavLink>
        </div>

        @if (AuthService.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/profile">Profile</NavLink>
            </div>
        }

        @if (AuthService.IsLoggedIn && AuthService.Role == "Admin")
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/admin">Admin Dashboard</NavLink>
            </div>
        }

        <div class="dropdown-divider border-white opacity-50"></div>

        @if (!AuthService.IsLoggedIn)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/login">Login</NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="/register">Register</NavLink>
            </div>
        }
        else
        {
            <div class="nav-item px-3">
                <a href="javascript:void(0);" class="nav-link" @onclick="Logout">Logout</a>
            </div>
        }
    </nav>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnChange += HandleAuthChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        var role = await JwtService.GetRoleAsync();

        if (!string.IsNullOrWhiteSpace(role))
        {
            AuthService.SetUser(role);
        }
    }

    private async Task Logout()
    {
        var client = await AuthorizedClient.GetClientAsync();

        await client.PostAsync("api/auth/logout", null);

        await JSRuntime.InvokeVoidAsync("sessionStorage.removeItem", "jwt");
        AuthService.Logout();
        Navigation.NavigateTo("/", forceLoad: true);
    }

    private void HandleAuthChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AuthService.OnChange -= HandleAuthChanged;
    }
}